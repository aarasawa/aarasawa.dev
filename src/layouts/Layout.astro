---
import '../styles/global.scss';
import Nav from '../components/Nav.tsx';
import CookieConsent from '../components/CookieConsent.tsx';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Alex Arasawa | Engineering & Portfolio',
  description = 'Portfolio of Alex Arasawa - Applications Engineer and Full-Stack Developer specialized in civic tech and nonprofit infrastructure.',
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=VT323&family=Outfit:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <!-- Noise grain layer (CRT texture) -->
    <div class="noise-layer" aria-hidden="true"></div>

    <!-- Nav — React island for dropdown + mobile menu interactivity -->
    <Nav currentPath={currentPath} client:load />

    <!-- Page content -->
    <main class="app__main" id="main-content">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="app__footer">
      <div class="app__footer-container">
        <div class="app__footer-copy">
          © 2026
          <span class="app__footer-agency">Deep Phosphor Studios</span>
          <span class="app__footer-dot"></span>
          All Rights Reserved
          <span class="app__footer-dot"></span>
          <a href="/privacy" class="inline-link" style="color:inherit;text-decoration:none;">
            Privacy Policy & CCPA
          </a>
        </div>
        <div class="app__footer-sig">ARASAWA.DEV</div>
      </div>
    </footer>

    <!-- Cookie consent — React island -->
    <CookieConsent client:load />

    <!-- Google Analytics -->
    <script>
      // GA is initialised in the Nav island on mount.
      // Individual page views are tracked there via ReactGA.send.
    </script>
  </body>
</html>

<style is:global>
  @use "../styles/variables" as *;

  .app__main {
    max-width: 56rem;
    margin: 0 auto;
    padding: 0 1.5rem 6rem;
  }

  .app__footer {
    border-top: 1px solid rgba(#FFB347, 0.1);
    padding: 3rem 0;
  }

  .app__footer-container {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;

    @media (min-width: 768px) {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .app__footer-copy {
    font-family: "Share Tech Mono", monospace;
    font-size: 0.75rem;
    color: rgba(#FFB347, 0.7);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .app__footer-agency {
    color: #FFB347;
  }

  .app__footer-dot {
    width: 0.25rem;
    height: 0.25rem;
    background-color: rgba(#FFB347, 0.4);
    border-radius: 50%;
    display: inline-block;
  }

  .app__footer-sig {
    font-family: "VT323", monospace;
    font-size: 1.25rem;
    color: #FFB347;
    letter-spacing: 0.3em;
    opacity: 0.9;
    text-shadow: 0 0 16px #FFB347, 0 0 32px rgba(#FFB347, 0.5);
  }
</style>