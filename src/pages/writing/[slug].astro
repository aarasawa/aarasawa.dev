---
export const prerender = false;

import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import MarkdownPost from '../../components/MarkdownPost.tsx';

// ── slug helper — must match index.astro exactly ─────────
function deriveSlug(title: string, frontmatterSlug?: string): string {
  if (frontmatterSlug) return frontmatterSlug;
  return title
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9\s-]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .replace(/(^-|-$)/g, '');
}

// ── resolve post from URL param ──────────────────────────
const { slug } = Astro.params;
if (!slug) return Astro.redirect('/writing');

const allPosts = await getCollection('posts', ({ data }) => data.draft !== true);

const post = allPosts.find(p =>
  deriveSlug(p.data.title, p.data.slug) === slug
);

if (!post) return Astro.redirect('/writing');

// ── prev / next computed dynamically ────────────────────
const sorted = [...allPosts].sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf()
);
const idx      = sorted.findIndex(p => p.id === post.id);
const prevPost = sorted[idx + 1] ?? null;
const nextPost = sorted[idx - 1] ?? null;

// ── word count + reading time ────────────────────────────
const words       = post.body.split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(words / 200));

// ── render markdown ──────────────────────────────────────
const { Content } = await post.render();

// ── shape data for MarkdownPost component ────────────────
const postData = {
  slug:        deriveSlug(post.data.title, post.data.slug),
  title:       post.data.title,
  published:   post.data.published.toISOString(),
  description: post.data.description ?? '',
  tags:        post.data.tags ?? [],
  category:    post.data.category ?? '',
  wordCount:   words,
  readingTime,
  prevTitle:   prevPost?.data.title ?? '',
  prevSlug:    prevPost ? deriveSlug(prevPost.data.title, prevPost.data.slug) : '',
  nextTitle:   nextPost?.data.title ?? '',
  nextSlug:    nextPost ? deriveSlug(nextPost.data.title, nextPost.data.slug) : '',
};
---

<Layout title={`${post.data.title} — Alex Arasawa`}>
  <MarkdownPost post={postData} client:load>
    <Content />
  </MarkdownPost>
</Layout>